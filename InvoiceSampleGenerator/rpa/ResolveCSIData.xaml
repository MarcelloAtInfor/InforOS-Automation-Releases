<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:iaw="clr-namespace:Infor.Activities.Workflow;assembly=Infor.Activities.Workflow"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="projectPath" Type="InArgument(x:String)" />
    <x:Property Name="tenantURL" Type="InArgument(x:String)" />
    <x:Property Name="site" Type="InArgument(x:String)" />
    <x:Property Name="requestJsonPath" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="enrichedRequestJsonPath" Type="OutArgument(x:String)" />
    <x:Property Name="operationStatus" Type="OutArgument(x:String)" />
    <x:Property Name="errorMessage" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings><x:Null /></mva:VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
      <x:String>System.Collections.Generic</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Activities</AssemblyReference>
      <AssemblyReference>Microsoft.VisualBasic</AssemblyReference>
      <AssemblyReference>Infor.Activities.Sys</AssemblyReference>
      <AssemblyReference>Infor.Activities.Workflow</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Resolve CSI Data">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="requestText" />
      <Variable x:TypeArguments="x:String" Name="normalizedText" />
      <Variable x:TypeArguments="x:Boolean" Name="needVendors" />
      <Variable x:TypeArguments="x:Boolean" Name="needItems" />
      <Variable x:TypeArguments="x:Boolean" Name="needPoNumber" />
      <Variable x:TypeArguments="x:Boolean" Name="needAnything" />
      <Variable x:TypeArguments="x:String" Name="tempFolder" />
      <Variable x:TypeArguments="x:String" Name="vendorResponseJson" Default="" />
      <Variable x:TypeArguments="x:String" Name="itemResponseJson" Default="" />
      <Variable x:TypeArguments="x:String" Name="poNumberResponseJson" Default="" />
      <Variable x:TypeArguments="x:String" Name="poPrefix" Default="PODM" />
      <Variable x:TypeArguments="x:String" Name="vendorFilter" Default="" />
      <Variable x:TypeArguments="x:String" Name="itemFilter" Default="UnitCost &gt; 0" />
      <Variable x:TypeArguments="x:String" Name="selectedVendorRaw" Default="" />
      <Variable x:TypeArguments="x:String" Name="selectedItemsRaw" Default="" />
      <Variable x:TypeArguments="x:String" Name="vendorRecordCap" Default="10" />
      <Variable x:TypeArguments="x:String" Name="itemRecordCap" Default="30" />
      <Variable x:TypeArguments="x:String" Name="docCount" Default="1" />
      <Variable x:TypeArguments="x:String" Name="lineCount" Default="3" />
      <Variable x:TypeArguments="scg:IDictionary(x:String, x:Object)" Name="idoOutputDict" />
      <Variable x:TypeArguments="x:String" Name="idoStatus" />
      <Variable x:TypeArguments="x:String" Name="resolveScriptPath" />
      <Variable x:TypeArguments="x:String" Name="resolveArgs" />
      <Variable x:TypeArguments="x:Object" Name="resolveProcess" />
      <Variable x:TypeArguments="x:Boolean" Name="resolveExited" />
      <Variable x:TypeArguments="x:Int32" Name="resolveExitCode" Default="-1" />
      <Variable x:TypeArguments="x:String" Name="vendorTempPath" />
      <Variable x:TypeArguments="x:String" Name="itemTempPath" />
      <Variable x:TypeArguments="x:String" Name="poTempPath" />
    </Sequence.Variables>
    <TryCatch DisplayName="ResolveCSI Try-Catch">
      <TryCatch.Try>
        <Sequence DisplayName="Main Logic">
    <Assign DisplayName="Init Status">
      <Assign.To><OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Init Error">
      <Assign.To><OutArgument x:TypeArguments="x:String">[errorMessage]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="Set Temp Folder">
      <Assign.To><OutArgument x:TypeArguments="x:String">[tempFolder]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(System.IO.Path.GetDirectoryName(logFile), "csi_resolve_" + System.Guid.NewGuid().ToString("N"))]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set Enriched Request Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[enrichedRequestJsonPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(tempFolder, "enriched_request.json")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set Vendor Temp Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[vendorTempPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(tempFolder, "vendors.json")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set Item Temp Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[itemTempPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(tempFolder, "items.json")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set PO Temp Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[poTempPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(tempFolder, "po_numbers.json")]</InArgument></Assign.Value>
    </Assign>

    <!-- Read request to determine what needs resolution -->
    <Assign DisplayName="Read Request Text">
      <Assign.To><OutArgument x:TypeArguments="x:String">[requestText]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(requestJsonPath)]</InArgument></Assign.Value>
    </Assign>

    <!-- Normalize a copy for boolean checks (strip whitespace so JSON formatting doesn't matter) -->
    <Assign DisplayName="Build Normalized Text">
      <Assign.To><OutArgument x:TypeArguments="x:String">[normalizedText]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[requestText.Replace(" ", "").Replace(vbTab, "")]</InArgument></Assign.Value>
    </Assign>

    <!-- Determine needs using simple string checks on normalized text -->
    <Assign DisplayName="Check Need Vendors">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[needVendors]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[normalizedText.Contains("""useExistingVendors"":""True""")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Check Need Items">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[needItems]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[normalizedText.Contains("""useExistingItems"":""True""")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Check Need PO Number">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[needPoNumber]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[normalizedText.Contains("""lookupLatestNumbers"":""True""") AndAlso Not normalizedText.Contains("""isNonPo"":""True""")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Extract PO Prefix">
      <Assign.To><OutArgument x:TypeArguments="x:String">[poPrefix]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(requestText.Contains("""poPrefix"":"), requestText.Substring(requestText.IndexOf("""poPrefix"":") + 12).Trim().TrimStart(""""c).Split(""""c)(0), "PODM")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Extract Doc Count">
      <Assign.To><OutArgument x:TypeArguments="x:String">[docCount]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(requestText.Contains("""documentCount"":"), requestText.Substring(requestText.IndexOf("""documentCount"":") + 16).Trim().TrimStart(""""c).Split(""""c)(0), "1")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Extract Line Count">
      <Assign.To><OutArgument x:TypeArguments="x:String">[lineCount]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(requestText.Contains("""lineCount"":"), requestText.Substring(requestText.IndexOf("""lineCount"":") + 13).Trim().TrimStart(""""c).Split(""""c)(0), "3")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Extract Selected Vendor">
      <Assign.To><OutArgument x:TypeArguments="x:String">[selectedVendorRaw]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(requestText.Contains("""selectedVendor"":"), requestText.Substring(requestText.IndexOf("""selectedVendor"":") + 18).Trim().TrimStart(""""c).Split(""""c)(0).Trim(), "")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Extract Selected Items">
      <Assign.To><OutArgument x:TypeArguments="x:String">[selectedItemsRaw]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(requestText.Contains("""selectedItems"":"), requestText.Substring(requestText.IndexOf("""selectedItems"":") + 17).Trim().TrimStart(""""c).Split(""""c)(0).Trim(), "")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Build Targeted Vendor Filter">
      <Assign.To><OutArgument x:TypeArguments="x:String">[vendorFilter]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(selectedVendorRaw), vendorFilter, "VendNum = '" + selectedVendorRaw.Replace("|", "' OR VendNum = '") + "'")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Build Targeted Item Filter">
      <Assign.To><OutArgument x:TypeArguments="x:String">[itemFilter]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(selectedItemsRaw), itemFilter, "(Item = '" + selectedItemsRaw.Replace("|", "' OR Item = '") + "') AND UnitCost > 0")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set Vendor RecordCap">
      <Assign.To><OutArgument x:TypeArguments="x:String">[vendorRecordCap]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[CStr(Math.Max(10, CInt(docCount)))]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set Item RecordCap">
      <Assign.To><OutArgument x:TypeArguments="x:String">[itemRecordCap]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[CStr(Math.Max(20, CInt(docCount) * CInt(If(lineCount.Contains("-"), lineCount.Split("-"c)(1), lineCount))))]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Check Need Anything">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[needAnything]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[needVendors OrElse needItems OrElse needPoNumber]</InArgument></Assign.Value>
    </Assign>

    <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log CSI Resolve Start" Line="[System.Environment.NewLine + &quot;ResolveCSIData:&quot; + System.Environment.NewLine + &quot;  NeedVendors: &quot; + needVendors.ToString() + System.Environment.NewLine + &quot;  NeedItems: &quot; + needItems.ToString() + System.Environment.NewLine + &quot;  NeedPoNumber: &quot; + needPoNumber.ToString()]" Source="[logFile]" />

    <If Condition="[needAnything]" DisplayName="If CSI Resolution Needed">
      <If.Then>
        <Sequence DisplayName="Perform CSI Lookups">

          <!-- Vendor lookup -->
          <If Condition="[needVendors]" DisplayName="If Need Vendors">
            <If.Then>
              <Sequence DisplayName="Lookup Vendors">
                <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;tenantURL&quot;, tenantURL}, {&quot;site&quot;, site}, {&quot;idoName&quot;, &quot;SLVendors&quot;}, {&quot;properties&quot;, &quot;VendNum,Name,VadAddr_1,VadAddr_2,VadAddr_3,VadAddr_4,VadCity,VadState,VadZip,Phone,ExternalEmailAddr&quot;}, {&quot;filter&quot;, vendorFilter}, {&quot;orderBy&quot;, &quot;VendNum ASC&quot;}, {&quot;recordCap&quot;, vendorRecordCap}, {&quot;logFile&quot;, logFile}}]" ContinueOnError="True" DisplayName="Execute Vendor IDO Load" OutputArguments="[idoOutputDict]" WorkflowFile="[projectPath + &quot;\ExecuteIdoLoad.xaml&quot;]" />
                <Assign DisplayName="Read Vendor Response">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[vendorResponseJson]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">[If(idoOutputDict IsNot Nothing AndAlso idoOutputDict.ContainsKey("responseJson"), idoOutputDict("responseJson").ToString(), "")]</InArgument></Assign.Value>
                </Assign>
                <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Vendor Result" Line="[&quot;  VendorLookup: &quot; + If(String.IsNullOrWhiteSpace(vendorResponseJson), &quot;no response&quot;, vendorResponseJson.Length.ToString() + &quot; chars&quot;)]" Source="[logFile]" />
              </Sequence>
            </If.Then>
          </If>

          <!-- Item lookup -->
          <If Condition="[needItems]" DisplayName="If Need Items">
            <If.Then>
              <Sequence DisplayName="Lookup Items">
                <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;tenantURL&quot;, tenantURL}, {&quot;site&quot;, site}, {&quot;idoName&quot;, &quot;SLItems&quot;}, {&quot;properties&quot;, &quot;Item,Description,UM,UnitCost&quot;}, {&quot;filter&quot;, itemFilter}, {&quot;orderBy&quot;, &quot;Item ASC&quot;}, {&quot;recordCap&quot;, itemRecordCap}, {&quot;logFile&quot;, logFile}}]" ContinueOnError="True" DisplayName="Execute Item IDO Load" OutputArguments="[idoOutputDict]" WorkflowFile="[projectPath + &quot;\ExecuteIdoLoad.xaml&quot;]" />
                <Assign DisplayName="Read Item Response">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[itemResponseJson]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">[If(idoOutputDict IsNot Nothing AndAlso idoOutputDict.ContainsKey("responseJson"), idoOutputDict("responseJson").ToString(), "")]</InArgument></Assign.Value>
                </Assign>
                <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Item Result" Line="[&quot;  ItemLookup: &quot; + If(String.IsNullOrWhiteSpace(itemResponseJson), &quot;no response&quot;, itemResponseJson.Length.ToString() + &quot; chars&quot;)]" Source="[logFile]" />
              </Sequence>
            </If.Then>
          </If>

          <!-- PO number lookup -->
          <If Condition="[needPoNumber]" DisplayName="If Need PO Number">
            <If.Then>
              <Sequence DisplayName="Lookup PO Numbers">
                <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;tenantURL&quot;, tenantURL}, {&quot;site&quot;, site}, {&quot;idoName&quot;, &quot;SLPos&quot;}, {&quot;properties&quot;, &quot;PoNum&quot;}, {&quot;filter&quot;, &quot;PoNum LIKE '&quot; + poPrefix + &quot;%'&quot;}, {&quot;orderBy&quot;, &quot;PoNum DESC&quot;}, {&quot;recordCap&quot;, &quot;1&quot;}, {&quot;logFile&quot;, logFile}}]" ContinueOnError="True" DisplayName="Execute PO Number IDO Load" OutputArguments="[idoOutputDict]" WorkflowFile="[projectPath + &quot;\ExecuteIdoLoad.xaml&quot;]" />
                <Assign DisplayName="Read PO Number Response">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[poNumberResponseJson]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">[If(idoOutputDict IsNot Nothing AndAlso idoOutputDict.ContainsKey("responseJson"), idoOutputDict("responseJson").ToString(), "")]</InArgument></Assign.Value>
                </Assign>
                <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log PO Number Result" Line="[&quot;  PoNumberLookup: &quot; + If(String.IsNullOrWhiteSpace(poNumberResponseJson), &quot;no response&quot;, poNumberResponseJson.Length.ToString() + &quot; chars&quot;)]" Source="[logFile]" />
              </Sequence>
            </If.Then>
          </If>

          <!-- Write IDO responses to temp files, then invoke PS1 to merge -->
          <ias:Directory_Create ErrorCode="{x:Null}" OutputPath="{x:Null}" ContinueOnError="True" DisplayName="Create Temp Folder" Name="[System.IO.Path.GetFileName(tempFolder)]" Target="[System.IO.Path.GetDirectoryName(tempFolder)]" />
          <If Condition="[Not String.IsNullOrWhiteSpace(vendorResponseJson)]" DisplayName="Write Vendor Temp">
            <If.Then>
              <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Write Vendor File" Line="[vendorResponseJson]" Source="[vendorTempPath]" />
            </If.Then>
          </If>
          <If Condition="[Not String.IsNullOrWhiteSpace(itemResponseJson)]" DisplayName="Write Item Temp">
            <If.Then>
              <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Write Item File" Line="[itemResponseJson]" Source="[itemTempPath]" />
            </If.Then>
          </If>
          <If Condition="[Not String.IsNullOrWhiteSpace(poNumberResponseJson)]" DisplayName="Write PO Temp">
            <If.Then>
              <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Write PO File" Line="[poNumberResponseJson]" Source="[poTempPath]" />
            </If.Then>
          </If>

          <!-- Invoke PowerShell to merge -->
          <Assign DisplayName="Resolve Script Path">
            <Assign.To><OutArgument x:TypeArguments="x:String">[resolveScriptPath]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[projectPath + "\scripts\resolve_csi_data.ps1"]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Build Resolve Args">
            <Assign.To><OutArgument x:TypeArguments="x:String">[resolveArgs]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">["-ExecutionPolicy Bypass -File """ + resolveScriptPath + """ -RequestJsonPath """ + requestJsonPath + """ -EnrichedRequestJsonPath """ + enrichedRequestJsonPath + """" + If(System.IO.File.Exists(vendorTempPath), " -VendorResponseJsonPath """ + vendorTempPath + """", "") + If(System.IO.File.Exists(itemTempPath), " -ItemResponseJsonPath """ + itemTempPath + """", "") + If(System.IO.File.Exists(poTempPath), " -PoNumberResponseJsonPath """ + poTempPath + """", "")]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Start Resolve Process">
            <Assign.To><OutArgument x:TypeArguments="x:Object">[resolveProcess]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Object">[System.Diagnostics.Process.Start(New System.Diagnostics.ProcessStartInfo() With {.FileName = "powershell.exe", .Arguments = resolveArgs, .CreateNoWindow = True, .WindowStyle = System.Diagnostics.ProcessWindowStyle.Hidden})]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Wait For Resolve">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[resolveExited]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">[If(resolveProcess Is Nothing, False, CType(resolveProcess, System.Diagnostics.Process).WaitForExit(60000))]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Capture Resolve Exit Code">
            <Assign.To><OutArgument x:TypeArguments="x:Int32">[resolveExitCode]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Int32">[If(resolveProcess Is Nothing OrElse Not resolveExited, -1, CType(resolveProcess, System.Diagnostics.Process).ExitCode)]</InArgument></Assign.Value>
          </Assign>

          <If Condition="[resolveExited AndAlso resolveExitCode = 0 AndAlso System.IO.File.Exists(enrichedRequestJsonPath)]" DisplayName="Check Resolve Success">
            <If.Then>
              <Assign DisplayName="Set Success">
                <Assign.To><OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value>
              </Assign>
            </If.Then>
            <If.Else>
              <Sequence DisplayName="Handle Resolve Failure">
                <Assign DisplayName="Set Failed">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value>
                </Assign>
                <Assign DisplayName="Set Resolve Error">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[errorMessage]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">[If(Not resolveExited, "CSI resolve script timed out.", "CSI resolve script failed with exit code " + resolveExitCode.ToString())]</InArgument></Assign.Value>
                </Assign>
                <Assign DisplayName="Fallback to Original Request">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[enrichedRequestJsonPath]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">[requestJsonPath]</InArgument></Assign.Value>
                </Assign>
              </Sequence>
            </If.Else>
          </If>

        </Sequence>
      </If.Then>
      <If.Else>
        <Sequence DisplayName="Skip CSI Resolution">
          <Assign DisplayName="Set Skipped Status">
            <Assign.To><OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">["SKIPPED"]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Use Original Request">
            <Assign.To><OutArgument x:TypeArguments="x:String">[enrichedRequestJsonPath]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[requestJsonPath]</InArgument></Assign.Value>
          </Assign>
        </Sequence>
      </If.Else>
    </If>

    <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log CSI Resolve Result" Line="[System.Environment.NewLine + &quot;ResolveCSIData Result:&quot; + System.Environment.NewLine + &quot;  Status: &quot; + operationStatus + System.Environment.NewLine + &quot;  EnrichedRequest: &quot; + enrichedRequestJsonPath + If(String.IsNullOrWhiteSpace(errorMessage), &quot;&quot;, System.Environment.NewLine + &quot;  Error: &quot; + errorMessage)]" Source="[logFile]" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="ex" />
            </ActivityAction.Argument>
            <Sequence DisplayName="Handle Exception">
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[errorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[ex.Message]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[enrichedRequestJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[requestJsonPath]</InArgument></Assign.Value></Assign>
              <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log Exception" Line="[System.Environment.NewLine + &quot;EXCEPTION in ResolveCSIData:&quot; + System.Environment.NewLine + &quot;Message: &quot; + ex.Message + System.Environment.NewLine + &quot;StackTrace: &quot; + ex.StackTrace]" Source="[logFile]" />
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>
  </Sequence>
</Activity>
