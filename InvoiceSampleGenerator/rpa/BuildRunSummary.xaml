<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="requestJsonPath" Type="InArgument(x:String)" />
    <x:Property Name="rendererStatus" Type="InArgument(x:String)" />
    <x:Property Name="rendererError" Type="InArgument(x:String)" />
    <x:Property Name="rendererResponseJson" Type="InArgument(x:String)" />
    <x:Property Name="rendererResponseJsonPath" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="responseJson" Type="OutArgument(x:String)" />
    <x:Property Name="responseJsonPath" Type="OutArgument(x:String)" />
    <x:Property Name="operationStatus" Type="OutArgument(x:String)" />
    <x:Property Name="errorMessage" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings><x:Null /></mva:VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <Sequence DisplayName="Build Run Summary">
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(rendererStatus), "FAILED", rendererStatus)]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[errorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(rendererError), "", rendererError)]</InArgument></Assign.Value></Assign>
    <Assign>
      <Assign.To><OutArgument x:TypeArguments="x:String">[responseJson]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(Not String.IsNullOrWhiteSpace(rendererResponseJson), rendererResponseJson, "{""operationStatus"":""" + operationStatus + """,""requestJsonPath"":""" + If(requestJsonPath Is Nothing, "", requestJsonPath.Replace("\", "\\").Replace("""", "'")) + """,""responseJsonPath"":""" + If(rendererResponseJsonPath Is Nothing, "", rendererResponseJsonPath.Replace("\", "\\").Replace("""", "'")) + """,""errorMessage"":""" + If(errorMessage Is Nothing, "", errorMessage.Replace("\", "\\").Replace("""", "'")) + """}")]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[responseJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(rendererResponseJsonPath), "", rendererResponseJsonPath)]</InArgument></Assign.Value></Assign>
    <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Summary Builder" Line="[System.Environment.NewLine + &quot;BuildRunSummary:&quot; + System.Environment.NewLine + &quot;  Status: &quot; + operationStatus + If(String.IsNullOrWhiteSpace(rendererResponseJsonPath), &quot;&quot;, System.Environment.NewLine + &quot;  ResponseArtifact: &quot; + rendererResponseJsonPath) + If(String.IsNullOrWhiteSpace(errorMessage), &quot;&quot;, System.Environment.NewLine + &quot;  Error: &quot; + errorMessage)]" Source="[logFile]" />
  </Sequence>
</Activity>
